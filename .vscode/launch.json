{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Andy: Run Desktop",
      "type": "node-terminal",
      "request": "launch",
      "command": "./gradlew runDistributable",
      "cwd": "${workspaceFolder}",
      "env": {
        "ANDROID_HOME": "${env:HOME}/Library/Android/sdk",
        "PATH": "/Applications/scrcpy:${env:HOME}/Library/Android/sdk/platform-tools:${env:PATH}"
      }
    },
    {
      "name": "Andy: Record Desktop Screenshots",
      "type": "node-terminal",
      "request": "launch",
      "command": "./gradlew recordRoborazziDesktop",
      "cwd": "${workspaceFolder}",
      "env": {
        "ANDROID_HOME": "${env:HOME}/Library/Android/sdk",
        "PATH": "/Applications/scrcpy:${env:HOME}/Library/Android/sdk/platform-tools:${env:PATH}"
      }
    },
    {
      "name": "Andy: Run Web",
      "type": "node-terminal",
      "request": "launch",
      "command": "./gradlew wasmJsBrowserDevelopmentRun",
      "cwd": "${workspaceFolder}"
    }
  ]
}
